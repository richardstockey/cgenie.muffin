# *******************************************************************
# *** plasim_test_20230915_userconfig ******************************
# *******************************************************************
#
# *** CLIMATE *******************************************************
# Climate section omitted by RGS 20230915, not used w PLASIM?
# set climate feedback (climate responding to changing pCO2)
# ea_36=y
#
# *** BIOLOGICAL NEW PRODUCTION *************************************
bg_par_bio_k0_PO4=2.27102E-05 # maximum PO4 consumption rate (mol kg-1 yr-1)
bg_par_bio_c0_PO4=1.21364E-06 # [PO4] M-M half-sat value (mol kg-1)
#
# *** ORGANIC MATTER EXPORT RATIOS **********************************
bg_par_bio_red_POP_POC=117.0
bg_par_bio_red_POP_PO2=-170.0
#
# *** INORGANIC MATTER EXPORT RATIOS ********************************
bg_par_bio_red_POC_CaCO3=0.076451613 # base CaCO3:POC export ratio
bg_par_bio_red_POC_CaCO3_pP=0.510762052 # exponent for modifier of CaCO3:POC export ratio
#
# *** REMINERALIZATION **********************************************
bg_par_bio_remin_POC_frac2=0.031470878 # initial fractional abundance of POC component #2-->
bg_par_bio_remin_POC_eL1=802.2577104 # remineralization length #1 for POC-->
bg_par_bio_remin_POC_eL2=1000000.0 # remineralization length #2 for POC-->
bg_par_bio_remin_CaCO3_frac2=0.22708127 # initial fractional abundance of CaCO3 component #2-->
bg_par_bio_remin_CaCO3_eL1=1315.250789 # remineralization length #1 for CaCO3-->
bg_par_bio_remin_CaCO3_eL2=1000000.0 # remineralization length #2 for CaCO3-->
#
# *** DATA SAVING ***************************************************
#
bg_par_infile_slice_name='save_timeslice_EVERY1.dat'
bg_par_infile_sig_name='save_timeseries_EVERY1.dat'
#
# *** FORCINGS ******************************************************
#
bg_par_forcing_name="pyyyyz.RpCO2_Rp13CO2"
bg_par_atm_force_scale_val_3=278.0E-06
bg_par_atm_force_scale_val_4=-6.5
bg_ctrl_force_oldformat=.false.
ac_ctrl_continuing=.false.
#
# *** MISC **********************************************************
#
bg_par_gastransfer_a=0.460061804
bg_ctrl_force_windspeed=.false.
bg_ctrl_continuing=.false.
bg_par_misc_t_start=0